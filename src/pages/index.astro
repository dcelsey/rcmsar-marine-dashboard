---
import Base from '../layouts/Base.astro';
import { stationList } from '../lib/stations';

const stationNumber = (slug: string): number => {
  const n = Number(slug.replace(/^sar/, ''));
  return Number.isFinite(n) ? n : -1;
};
const stations = stationList().slice().sort((a, b) => stationNumber(a.slug) - stationNumber(b.slug));
---
<Base title="RCMSAR Marine Conditions">
  <div class="wrap landing-wrap">
    <header class="landing-hero">
      <img class="landing-logo" src="/logo-rcmsar.png" alt="Royal Canadian Marine Search and Rescue" />
      <h1>Marine Conditions</h1>
      <p class="muted">Local marine conditions dashboards for RCMSAR units. Pick a station.</p>
      <input
        id="station-search"
        class="station-search"
        type="search"
        placeholder="Search stations…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search stations"
      />
    </header>
    <div class="station-grid" id="station-grid">
      {stations.map(s => (
        <div class="card station-card" data-search={`${s.brand.short} ${s.brand.tagline} ${s.slug}`.toLowerCase()}>
          <a href={`/${s.slug}/`} class="station-primary">
            <img class="station-logo" src={s.brand.logoSrc ?? '/logo-rcmsar.png'}
                 alt={s.brand.logoAlt ?? 'Royal Canadian Marine Search and Rescue'} />
            <div>
              <b>{s.brand.short}</b>
              <span class="muted tiny">{s.brand.tagline}</span>
            </div>
          </a>
          <div class="linkrow" style="margin-top:14px">
            <a href={`/${s.slug}/kiosk`}>Kiosk view ↗</a>
            <a href={`/${s.slug}/widescreen`}>Widescreen view ↗</a>
          </div>
        </div>
      ))}
    </div>
    <p id="station-empty" class="muted station-empty" hidden>No stations match that search.</p>
  </div>

  <script is:inline>
    (() => {
      const input = document.getElementById('station-search');
      const cards = Array.from(document.querySelectorAll('#station-grid .station-card'));
      const empty = document.getElementById('station-empty');
      if (!input || !cards.length) return;
      let timer;
      const apply = () => {
        const q = input.value.trim().toLowerCase();
        let shown = 0;
        for (const card of cards) {
          const hay = card.dataset.search || '';
          const match = !q || hay.includes(q);
          card.hidden = !match;
          if (match) shown++;
        }
        if (empty) empty.hidden = shown !== 0;
      };
      input.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(apply, 150);
      });
    })();
  </script>
</Base>

<style>
  .landing-wrap { padding-top: 40px; padding-bottom: 60px; }
  .landing-hero {
    text-align: center;
    margin: 0 auto 40px;
    max-width: 640px;
  }
  .landing-logo {
    height: 90px;
    width: auto;
    max-width: 320px;
    object-fit: contain;
    background: #fff;
    padding: 12px 20px;
    border-radius: 10px;
    display: inline-block;
    margin-bottom: 22px;
  }
  .landing-hero h1 {
    font-size: 30px;
    margin: 0 0 8px;
    letter-spacing: .2px;
  }
  .landing-hero p {
    margin: 0;
    font-size: 15px;
  }
  .station-search {
    display: block;
    width: 100%;
    max-width: 420px;
    margin: 22px auto 0;
    padding: 11px 14px;
    background: var(--card);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    box-shadow: var(--shadow);
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .station-search::placeholder { color: var(--muted); }
  .station-search:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(55, 182, 255, .18);
  }
  .station-empty {
    text-align: center;
    margin: 20px 0 0;
    font-size: 14px;
  }

  .station-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }
  .station-card { padding: 20px; }
  .station-primary {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--ink);
    text-decoration: none;
  }
  .station-primary:hover { text-decoration: none; }
  .station-primary:hover b { text-decoration: underline; }
  .station-logo {
    height: 44px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    background: #fff;
    padding: 4px 8px;
    border-radius: 6px;
    box-sizing: content-box;
    flex-shrink: 0;
  }
  .station-primary b { display: block; font-size: 17px; }
  .station-primary span { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }
</style>
