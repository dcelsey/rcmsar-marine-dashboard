---
import type { StationConfig } from '../lib/stations';
interface Props { station: StationConfig }
const { station } = Astro.props;
const { brand } = station;
---
<header class="top">
  <div class="wrap">
    <img class="brand-logo" src={brand.logoSrc} alt={brand.logoAlt} />
    <div class="brand"><b>{brand.short}</b><span>{brand.tagline}</span></div>
    <div class="spacer"></div>
    <div class="updated" id="updated">Loading…</div>
    <button class="refresh" id="refreshBtn" title="Refresh now">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <path d="M21 12a9 9 0 1 1-2.64-6.36" />
        <path d="M21 3v6h-6" />
      </svg>
      <span>Refresh</span>
    </button>
  </div>
</header>
