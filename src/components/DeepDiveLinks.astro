---
import type { StationConfig } from '../lib/stations';
interface Props { station: StationConfig }
const { station } = Astro.props;
---
<h2 class="section">Deep-dive sources</h2>
<div class="card">
  <div class="linkrow">
    {station.deepDive.map(link => (
      <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
    ))}
  </div>
</div>
