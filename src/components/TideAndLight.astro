<h2 class="section">Tide &amp; light</h2>
<div class="grid g3 tide-sun">
  <div class="card">
    <h3>Tide — Oak Bay (07130) <span class="r" id="tide-r"></span></h3>
    <div id="tide-chart"></div>
    <table id="tide-table" style="margin-top:10px">
      <thead><tr><th>Next tides</th><th class="num">Height</th><th class="num">Time</th></tr></thead>
      <tbody><tr><td colspan="3" class="skel">Loading…</td></tr></tbody>
    </table>
    <p class="tiny muted" style="margin:8px 2px 0">Metres, chart datum. Predictions (astronomical) from DFO IWLS.</p>
  </div>
  <div class="card">
    <h3>Sun &amp; twilight</h3>
    <table id="sun-table"><tbody><tr><td class="skel">Loading…</td></tr></tbody></table>
    <p class="tiny muted" style="margin:8px 2px 0">Computed locally (SunCalc) for Oak Bay.</p>
  </div>
</div>
