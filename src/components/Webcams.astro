---
import type { StationConfig } from '../lib/stations';
interface Props { station: StationConfig }
const { station } = Astro.props;
const { webcams } = station;
---
<h2 class="section">Webcam views</h2>
<div class="cam-grid">
  {webcams.map((cam, i) => (
    cam.kind === 'iframe' ? (
      <div class="card">
        <h3>{cam.title}</h3>
        <div class="cam-card-media" data-cam-index={i}>
          <div class="cam-video-scale">
            <iframe loading="lazy" src={cam.src} title={cam.title}></iframe>
          </div>
        </div>
        <div style="margin-top:10px;display:flex;gap:10px;flex-wrap:wrap;align-items:center">
          {cam.modal && (
            <button type="button" class="cam-open-btn" data-cam-open={i}>View larger</button>
          )}
          <a class="cam-open-btn" href={cam.sourceHref} target="_blank" rel="noopener">Open source page ↗</a>
        </div>
      </div>
    ) : (
      <div class="card">
        <h3>{cam.title}</h3>
        <a href={cam.href} target="_blank" rel="noopener"
           style="display:flex;min-height:220px;border:1px dashed var(--line);border-radius:10px;padding:16px;background:rgba(255,255,255,.03);color:var(--ink);text-decoration:none;align-items:center;justify-content:center;text-align:center;">
          <span><strong>{cam.ctaTitle}</strong><br><span class="tiny muted">{cam.ctaSubtitle}</span></span>
        </a>
        {cam.note && <p class="tiny muted" style="margin:8px 2px 0">{cam.note}</p>}
      </div>
    )
  ))}
</div>

{webcams.map((cam, i) => (
  cam.kind === 'iframe' && cam.modal && (
    <div class="modal-overlay" data-cam-modal={i} role="dialog" aria-modal="true" aria-labelledby={`cam-modal-title-${i}`}>
      <div class="modal-panel">
        <div class="modal-header">
          <h3 id={`cam-modal-title-${i}`}>{cam.title} — larger view</h3>
          <button class="modal-close" data-cam-close={i} aria-label="Close">✕</button>
        </div>
        <div class="modal-body" data-cam-modal-body={i}>
          <div class="cam-video-scale">
            <iframe loading="lazy" src={cam.src} title={`${cam.title} large view`}></iframe>
          </div>
        </div>
        <div class="modal-footer">If video does not load, open the source page for the full stream.</div>
      </div>
    </div>
  )
))}
