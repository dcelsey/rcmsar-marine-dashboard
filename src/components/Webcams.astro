<h2 class="section">Webcam views</h2>
<div class="cam-grid">
  <div class="card">
    <h3>Dallas Road webcam</h3>
    <div class="cam-card-media" id="dallasRoadCamContainer">
      <div class="cam-video-scale">
        <iframe loading="lazy"
          src="https://mds.multivista.com/index.cfm?fuseaction=aPublicWebcam.embed&WebcamPublicEmbedUID=8E2F0FF9-3D83-4193-ABA5-3B90D4AC4006&HLS=1&width=1024&height=576&background=none"
          title="Dallas Road webcam"></iframe>
      </div>
    </div>
    <div style="margin-top:10px;display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <button type="button" class="cam-open-btn" id="openDallasCam">View larger</button>
      <a class="cam-open-btn" href="https://windisgood.com/dallas-road-webcam-live.html" target="_blank" rel="noopener">Open source page ↗</a>
    </div>
  </div>
  <div class="card">
    <h3>Willows Beach webcam</h3>
    <a href="https://windisgood.com/willows-beach.html" target="_blank" rel="noopener"
       style="display:flex;min-height:220px;border:1px dashed var(--line);border-radius:10px;padding:16px;background:rgba(255,255,255,.03);color:var(--ink);text-decoration:none;align-items:center;justify-content:center;text-align:center;">
      <span><strong>Open Willows Beach webcam</strong><br><span class="tiny muted">Opens the WindIsGood webcam page ↗</span></span>
    </a>
    <p class="tiny muted" style="margin:8px 2px 0">The direct image URL is blocked by the source site, so this opens the official webcam page instead.</p>
  </div>
  <div class="card">
    <h3>Ross Bay webcam</h3>
    <a href="https://windisgood.com/ross-bay-webcam-live.html" target="_blank" rel="noopener"
       style="display:flex;min-height:220px;border:1px dashed var(--line);border-radius:10px;padding:16px;background:rgba(255,255,255,.03);color:var(--ink);text-decoration:none;align-items:center;justify-content:center;text-align:center;">
      <span><strong>Open Ross Bay webcam</strong><br><span class="tiny muted">Video owner has disabled embedding ↗</span></span>
    </a>
    <p class="tiny muted" style="margin:8px 2px 0">The YouTube video (via camstreamer) blocks external embeds, so this opens the source page instead.</p>
  </div>
</div>

<div class="modal-overlay" id="dallasCamModal" role="dialog" aria-modal="true" aria-labelledby="dallasCamModalTitle">
  <div class="modal-panel">
    <div class="modal-header">
      <h3 id="dallasCamModalTitle">Dallas Road webcam — larger view</h3>
      <button class="modal-close" id="closeDallasCam" aria-label="Close">✕</button>
    </div>
    <div class="modal-body" id="dallasCamModalBody">
      <div class="cam-video-scale">
        <iframe loading="lazy"
          src="https://mds.multivista.com/index.cfm?fuseaction=aPublicWebcam.embed&WebcamPublicEmbedUID=8E2F0FF9-3D83-4193-ABA5-3B90D4AC4006&HLS=1&width=1024&height=576&background=none"
          title="Dallas Road webcam large view"></iframe>
      </div>
    </div>
    <div class="modal-footer">If video does not load, open the source page for the full stream.</div>
  </div>
</div>
