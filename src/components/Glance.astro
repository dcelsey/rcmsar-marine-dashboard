---
import type { StationConfig } from '../lib/stations';
interface Props { station: StationConfig }
const { station } = Astro.props;
const { labels } = station;
---
<div class="glance" id="glance">
  <div class="tile">
    <div class="lbl">🌬 Wind</div>
    <div class="big skel" id="g-wind">—</div>
    <div class="sub" id="g-wind-sub">{labels.windSub}</div>
    <div class="src tiny muted" id="g-wind-src">&nbsp;</div>
  </div>
  <div class="tile">
    <div class="lbl">🌊 Sea state</div>
    <div class="big skel" id="g-sea">—</div>
    <div class="sub" id="g-sea-sub">{labels.seaSub}</div>
    <div class="src tiny muted" id="g-sea-src">&nbsp;</div>
  </div>
  <div class="tile">
    <div class="lbl">🌡 Weather</div>
    <div class="big skel" id="g-wx">—</div>
    <div class="sub" id="g-wx-sub">&nbsp;</div>
  </div>
  <div class="tile">
    <div class="lbl">🌙 Tide</div>
    <div class="big skel" id="g-tide">—</div>
    <div class="sub" id="g-tide-sub">{labels.tideSub}</div>
    <div class="src tiny muted" id="g-tide-src">&nbsp;</div>
  </div>
  <div class="tile">
    <div class="lbl">☀️ Sun</div>
    <div class="big skel" id="g-sun">—</div>
    <div class="sub" id="g-sun-sub">&nbsp;</div>
  </div>
</div>
