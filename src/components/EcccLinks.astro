---
import type { StationConfig } from '../lib/stations';
interface Props { station: StationConfig }
const { station } = Astro.props;
---
<h2 class="section">Official marine forecast &amp; warnings — ECCC</h2>
<div class="card">
  <h3>Environment Canada — the authoritative sea-state &amp; warnings source</h3>
  <p class="tiny muted" style="margin:0 0 10px">
    These bulletins carry official gale/storm warnings and the plain-language sea-state ("seas 1 metre…").
  </p>
  <div class="linkrow">
    {station.eccc.map(zone => (
      <a href={`https://weather.gc.ca/marine/forecast_e.html?mapID=${zone.mapId}&siteID=${zone.siteId}`}
         target="_blank" rel="noopener">{zone.label} ↗</a>
    ))}
  </div>
</div>
